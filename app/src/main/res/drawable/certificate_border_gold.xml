<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gold border -->
    <stroke
        android:width="6dp"
        android:color="#D4AF37" />   <!-- Pure Gold Color -->

    <!-- Rounded corners -->
    <corners android:radius="14dp" />

    <!-- Inner padding -->
    <padding
        android:left="20dp"
        android:top="20dp"
        android:right="20dp"
        android:bottom="20dp" />

    <!-- White background inside certificate -->
    <solid android:color="#FFFFFF" />

</shape>