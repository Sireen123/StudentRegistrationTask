<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ✅ Back Bar -->
    <include
        android:id="@+id/includeBack"
        layout="@layout/include_back_bar"
        android:contentDescription="Go back" />

    <!-- ✅ Back to Dashboard Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackToDashboard"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:minWidth="72dp"
        android:paddingHorizontal="12dp"
        android:text="Back"
        android:textAllCaps="false"
        android:textColor="?attr/colorPrimary"
        android:backgroundTint="?attr/colorSurfaceVariant"
        style="@style/Widget.Material3.Button"
        android:contentDescription="Go back to dashboard" />

    <!-- ✅ Certificate Fragment Container -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="16dp"
        android:foregroundGravity="center"
        android:contentDescription="Certificate preview area"
        android:importantForAccessibility="yes" />

    <!-- ✅ DOWNLOAD PDF -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDownloadPdf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Download as PDF"
        android:textAllCaps="false"
        android:padding="16dp"
        style="@style/Widget.Material3.Button"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="?attr/colorPrimary"
        android:textColor="@android:color/white"
        android:contentDescription="Download certificate as PDF" />

    <!-- ✅ SHARE PDF -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSharePdf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Share Certificate PDF"
        android:textAllCaps="false"
        android:padding="16dp"
        style="@style/Widget.Material3.Button"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="?attr/colorTertiary"
        android:textColor="@android:color/white"
        android:contentDescription="Share certificate PDF file" />

</LinearLayout>