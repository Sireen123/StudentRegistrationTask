<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#F5F6FA"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Optional top back bar include (keep if you use it) -->
    <include
        android:id="@+id/includeBack"
        layout="@layout/include_back_bar" />

    <!-- Explicit Back button -->
    <Button
        android:id="@+id/btnBackToDashboard"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#FFFFFF"
        android:minWidth="72dp"
        android:paddingHorizontal="12dp"
        android:text="Back"
        android:textAllCaps="false"
        android:textColor="#1976D2" />

    <!-- Fragment container fills available space -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="16dp"
        android:foregroundGravity="center" />

    <!-- Bottom actions -->
    <Button
        android:id="@+id/btnDownloadPdf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Download as PDF"
        android:textAllCaps="false"
        android:padding="16dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#1976D2"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btnSharePdf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Share Certificate PDF"
        android:textAllCaps="false"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:padding="16dp"
        android:backgroundTint="#2E7D32"
        android:textColor="#FFFFFF" />

</LinearLayout>