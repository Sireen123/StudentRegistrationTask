<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ✅ THEME SWITCH BUTTONS -->
    <LinearLayout
        android:id="@+id/themeButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="60dp"
        android:layout_marginEnd="16dp"
        android:elevation="30dp">

        <TextView
            android:id="@+id/btnLight"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:gravity="center"
            android:text="🌞"
            android:textSize="32sp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnDark"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:gravity="center"
            android:text="🌙"
            android:textSize="32sp"
            android:layout_marginStart="12dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>



    <!-- ✅ MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvHeading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Student Registration Application"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="24dp" />

        <!-- ✅ MATERIAL 3 BUTTON (WORKING) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExistingUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Existing User"
            style="@style/Widget.Material3.Button" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <!-- ✅ MATERIAL 3 BUTTON (WORKING) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="New User"
            style="@style/Widget.Material3.Button" />
    </LinearLayout>



    <!-- ✅ FAQ BLUE TILE (FIXED) -->
    <LinearLayout
        android:id="@+id/faqTileOutside"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:background="@drawable/bg_faq_blue"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_faq_chat"
            app:tint="@android:color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="FAQ"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="18sp" />
    </LinearLayout>

</FrameLayout>