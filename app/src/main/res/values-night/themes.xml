<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ✅ DARK THEME -->
    <style name="Theme.StudentRegistration" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>

        <item name="colorPrimary">@color/clg_primary</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:windowContentTransitions">true</item>
    </style>

    <!-- ✅ DARK SPLASH -->
    <style name="Theme.StudentReg.Splash.Legacy" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="Theme.StudentReg.Splash" parent="Theme.StudentReg.Splash.Legacy" />

    <!-- ✅ FIX: ADD MISSING NO ANIMATION THEME -->
    <style name="NoAnimTheme" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowActivityTransitions">false</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>

</resources>
