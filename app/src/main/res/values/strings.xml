    <string name="faq_title_text">FAQ</string>
    <string name="faq_footer_text">Need more help? Contact your college admin.</string>

    <string name="faq_question_1">How do I create a new student account?</string>
    <string name="faq_answer_1">Tap ‘New User’, fill the registration form, and submit.</string>

    <string name="faq_question_2">Why do I need phone OTP during login?</string>
    <string name="faq_answer_2">To protect your account from duplicate login.</string>

    <string name="faq_question_3">My phone shows “Invalid”. What should I check?</string>
    <string name="faq_answer_3">Fill all the details properly and try again.</string>

    <string name="faq_question_4">Why must I select Department and Semester?</string>
    <string name="faq_answer_4">They are required for fee calculation and certificate generation.</string>

    <string name="faq_question_5">How are fees shown after registration?</string>
    <string name="faq_answer_5">You will see Total, Paid and Balance details.</string>

    <string name="faq_question_6">Why do I need to add a digital signature?</string>
    <string name="faq_answer_6">To confirm your details before generating the certificate.</string>

    <string name="faq_question_7">Where is my certificate PDF saved?</string>
    <string name="faq_answer_7">Your PDF is saved inside the Downloads folder.</string>

    <string name="faq_question_8">Why are there different certificates?</string>
    <string name="faq_answer_8">The app shows a normal or arrear certificate based on arrear status.</string>


