<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ✅ FIX 1: Allow ALL files in app cache -->
    <cache-path
        name="app_cache"
        path="." />

    <!-- ✅ FIX 2: Allow ALL files in app files directory -->
    <files-path
        name="app_files"
        path="." />

    <!-- ✅ Optional: Allow external-cache files -->
    <external-cache-path
        name="ext_cache"
        path="." />

    <!-- ✅ Optional: Allow external-files directory -->
    <external-files-path
        name="ext_files"
        path="." />

</paths>